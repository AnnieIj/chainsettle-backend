// prisma/schema.prisma
// ChainSettle — Database schema
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS (mirror the on-chain contract enums)
// ============================================================

enum ShipmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  PROOF_SUBMITTED
  CONFIRMED
  DISPUTED
  RESOLVED
}

enum ArbiterStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  DECLINED
}

enum NotificationType {
  SHIPMENT_CREATED
  PROOF_SUBMITTED
  MILESTONE_CONFIRMED
  DISPUTE_RAISED
  DISPUTE_RESOLVED
  DISPUTE_EVIDENCE_SUBMITTED
  SHIPMENT_CANCELLED
  PAYMENT_RELEASED
  MILESTONE_OVERDUE
  COMMENT_ADDED
  SYSTEM_ALERT
  ARBITER_INVITED
  ARBITER_ACCEPTED
  ARBITER_DECLINED
}

enum CommentVisibility {
  ALL
  BUYER_SUPPLIER
  INTERNAL
}

enum DisputeRole {
  BUYER
  SUPPLIER
}

enum UserRole {
  BUYER
  SUPPLIER
  LOGISTICS
  ARBITER
  ADMIN
}

// ============================================================
// MODELS
// ============================================================

model User {
  id               String    @id @default(uuid())
  stellarAddress   String    @unique
  email            String?   @unique
  name             String?
  role             UserRole  @default(BUYER)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  buyerShipments     Shipment[]        @relation("BuyerShipments")
  supplierShipments  Shipment[]        @relation("SupplierShipments")
  logisticsShipments Shipment[]        @relation("LogisticsShipments")
  arbiterShipments   Shipment[]        @relation("ArbiterShipments")
  notifications      Notification[]
  auditLogs          AuditLog[]     @relation("AuditLogs")
  disputeEvidence    DisputeEvidence[]
  comments           ShipmentComment[]

  @@map("users")
}

model Shipment {
  id               String          @id  // matches on-chain shipment_id
  buyerAddress     String
  supplierAddress  String
  logisticsAddress String
  arbiterAddress   String
  tokenAddress     String
  totalAmount      BigInt          // stored in stroops (smallest unit)
  releasedAmount   BigInt          @default(0)
  status           ShipmentStatus  @default(ACTIVE)
  arbiterStatus    ArbiterStatus   @default(PENDING_ACCEPTANCE)
  txHash           String?         // ledger tx hash of creation
  createdLedger    Int?            // ledger sequence at creation

  // Token metadata (populated from TokenRegistry at creation time)
  tokenDecimals    Int     @default(7)
  tokenSymbol      String  @default("USDC")

  // Human-readable context fields
  description      String?         // what goods are being shipped (max 1000 chars)
  referenceNumber  String?         @unique // contract/PO reference for external systems
  metadata         Json?           // arbitrary key-value pairs (incoterms, port, etc)
  tags             String[]        @default([]) // searchable tags

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  buyer     User        @relation("BuyerShipments", fields: [buyerAddress], references: [stellarAddress])
  supplier  User        @relation("SupplierShipments", fields: [supplierAddress], references: [stellarAddress])
  logistics User        @relation("LogisticsShipments", fields: [logisticsAddress], references: [stellarAddress])
  arbiter   User        @relation("ArbiterShipments", fields: [arbiterAddress], references: [stellarAddress])
  milestones Milestone[]
  events    ChainEvent[]
  comments  ShipmentComment[]

  @@map("shipments")
}

model Milestone {
  id                 String          @id @default(uuid())
  shipmentId         String
  milestoneIndex     Int             // 0-based index matching on-chain
  name               String
  paymentPercent     Int             // 0-100
  proofHash          String?         // IPFS CID submitted by supplier/logistics
  status             MilestoneStatus @default(PENDING)
  paymentReleased    BigInt?         // exact amount released for this milestone
  confirmedAt        DateTime?
  dueAt              DateTime?       // optional deadline for milestone completion
  overdueNotifiedAt  DateTime?       // timestamp when overdue notification was sent (prevents re-notification)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // Relations
  shipment        Shipment          @relation(fields: [shipmentId], references: [id])
  disputeEvidence DisputeEvidence[]

  @@unique([shipmentId, milestoneIndex])
  @@map("milestones")
}

model DisputeEvidence {
  id          String      @id @default(uuid())
  milestoneId String
  submittedBy String      // Stellar address
  role        DisputeRole // BUYER or SUPPLIER
  description String      @db.Text
  ipfsCid     String?     // IPFS hash of uploaded file
  fileName    String?     // Original filename
  fileSize    Int?        // File size in bytes
  mimeType    String?     // MIME type of file
  createdAt   DateTime    @default(now())

  // Relations
  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [submittedBy], references: [stellarAddress])

  @@index([milestoneId])
  @@index([submittedBy])
  @@map("dispute_evidence")
}

model ChainEvent {
  id          String   @id @default(uuid())
  shipmentId  String?
  eventName   String   // e.g. "shipment_created", "milestone_confirmed"
  ledger      Int
  txHash      String
  payload     Json     // raw event payload from Stellar
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Relations
  shipment Shipment? @relation(fields: [shipmentId], references: [id])

  @@unique([txHash, eventName])
  @@index([shipmentId])
  @@index([eventName])
  @@index([processed])
  @@index([ledger])
  @@map("chain_events")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  data       Json?            // extra context (shipmentId, amount, etc.)
  read       Boolean          @default(false)
  emailSent  Boolean          @default(false)
  createdAt  DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

model FailedEvent {
  id            String    @id @default(uuid())
  eventName     String
  ledger        Int
  txHash        String
  payload       Json
  error         String    @db.Text
  attemptCount  Int       @default(1)
  lastAttemptAt DateTime  @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@unique([txHash, eventName])
  @@index([resolvedAt])
  @@map("failed_events")
}

model ShipmentComment {
  id            String            @id @default(uuid())
  shipmentId    String
  authorId      String
  body          String            @db.VarChar(2000)
  visibility    CommentVisibility @default(ALL)
  attachmentCid String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@index([shipmentId])
  @@index([authorId])
  @@map("shipment_comments")
}

model AuditLog {
  id             String   @id @default(uuid())
  userId         String
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  user User @relation("AuditLogs", fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
