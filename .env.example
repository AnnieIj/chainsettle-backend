# ============================================================
# ChainSettle Backend — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Database (PostgreSQL via Prisma)
DATABASE_URL=postgresql://chainsetttle:password@localhost:5432/chainsetttle_db

# Stellar Network
# Options: testnet | mainnet | futurenet
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Deployed contract IDs (set after deploying chainsetttle-contract)
CHAINSETTTLE_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
USDC_TOKEN_ADDRESS=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Backend Stellar account (for reading contract events — does NOT hold user funds)
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Email (Nodemailer — use any SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@chainsetttle.com

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Redis (for rate limiting and nonce storage)
REDIS_URL=redis://localhost:6379

# IPFS (for dispute evidence and document storage)
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=https://ipfs.io/ipfs

# Event Polling Interval (milliseconds) — how often to poll Stellar for new events
EVENT_POLLING_INTERVAL_MS=5000

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# IPFS (Pinata — for pinning proof documents)
# Get your JWT at https://app.pinata.cloud/keys
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
IPFS_API_KEY=your-pinata-jwt-token-here
